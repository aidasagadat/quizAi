# Secrets read by docker-compose.yml
# Copy this file to `.env` and fill in real values.

# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Generate strong values: openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-with-a-long-random-string
JWT_REFRESH_SECRET=change-me-with-another-long-random-string
